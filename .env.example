# Database Settings
# SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./data/fastpki.db

# PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastpki

# CA Settings
CA_KEY_SIZE=4096
CA_CERT_DAYS=3650
CERT_KEY_SIZE=2048
CERT_DAYS=365

# Security Settings
SECRET_KEY=generate-a-secure-random-key-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Private Key Encryption (optional — generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
# PRIVATE_KEY_ENCRYPTION_KEY=

# Logging
# LOG_LEVEL=INFO

# CORS Settings
BACKEND_CORS_ORIGINS=["*"]

# API Documentation
# Exposes /docs, /redoc, and /api/v1/openapi.json. Disabled by default to
# avoid leaking the API schema in production. Set to true for local dev.
# ENABLE_DOCS=true
